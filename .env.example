# --- Runtime / OAuth ---
MCP_PUBLIC_URL=https://your-public-hostname.example
MCP_HTTP_PORT=3100
MCP_GATE_PASSPHRASE=change-me

# --- Pronote (Python helper) ---
PYTHON_CMD=python

# --- GitHub ---
GITHUB_DEFAULT_OWNER=
GITHUB_PERSO_TOKEN=

# --- Microsoft 365 / Graph ---
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=

# --- OVH ---
OVH_MAIN_APP_KEY=
OVH_MAIN_APP_SECRET=
OVH_MAIN_CONSUMER_KEY=

# --- o2switch (cPanel) ---
O2SWITCH_HOST=
O2SWITCH_API_USER=
O2SWITCH_API_TOKEN=
O2SWITCH_PASSWORD=

# --- Steam ---
STEAM_API_KEY=
STEAM_ID=

# --- Google (Gmail / Calendar / Contacts) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Facebook / Meta Graph ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Optionnel : token utilisateur de bootstrap (sinon obtenu via facebook_auth_callback, stocké dans data/facebook_token.json)
FACEBOOK_USER_TOKEN=
# Optionnel : version de l'API Graph (défaut: v21.0)
FACEBOOK_API_VERSION=

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optionnel : token d'accès de bootstrap (sinon obtenu via le flux linkedin_auth_url, stocké dans data/linkedin_token.json)
LINKEDIN_ACCESS_TOKEN=
# Optionnel : version de l'API LinkedIn au format YYYYMM (défaut: 202505, à vérifier périodiquement)
LINKEDIN_API_VERSION=

# --- NEO / Pronote (EduConnect) ---
NEO_ENT_URL=
EDUCONNECT_LOGIN=
EDUCONNECT_PASSWORD=
PRONOTE_QR_PIN=

# --- PRIM / IDFM transit ---
PRIM_API_KEY=

# --- Synology NAS ---
SYNOLOGY_NAS_HOST=
SYNOLOGY_NAS_PORT=5001
SYNOLOGY_NAS_USER=
SYNOLOGY_NAS_PASSWORD=

# --- Pushover ---
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# --- ntfy ---
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=
NTFY_USERNAME=
NTFY_PASSWORD=

# --- WhatsApp Daemon ---
# Bearer token for secure API access (obtain from http://127.0.0.1:3099/auth/status after login)
WHATSAPP_DAEMON_TOKEN=
